{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workflow_state.schema.json",
  "title": "Bethesda mod translation workflow state",
  "type": "object",
  "required": [
    "schema_version",
    "game_id",
    "game_profile_version",
    "game_display_name",
    "support_level",
    "plugin_adapter",
    "plugin_adapter_version",
    "pex_category",
    "pex_writeback_status",
    "archive_delivery",
    "archive_materialization_enabled",
    "archive_allow_repack",
    "generated_at",
    "policy_path",
    "policy_sha256",
    "states"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "game_id": { "type": "string" },
    "game_profile_version": { "type": "integer", "minimum": 1 },
    "game_display_name": { "type": "string" },
    "support_level": { "type": "string" },
    "plugin_adapter": { "type": "string" },
    "plugin_adapter_version": { "type": "integer", "minimum": 1 },
    "pex_category": { "type": "string" },
    "pex_writeback_status": { "type": "string" },
    "archive_delivery": { "type": "string" },
    "archive_materialization_enabled": { "type": "boolean" },
    "archive_allow_repack": { "type": "boolean" },
    "generated_at": {
      "type": "string"
    },
    "policy_path": {
      "type": "string"
    },
    "policy_sha256": {
      "type": "string"
    },
    "project_state": {
      "type": "string"
    },
    "next_command": {
      "type": "string"
    },
    "states": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "mod",
          "state",
          "last_success_stage",
          "blocking_checks",
          "next_command",
          "allowed_scripts",
          "required_files",
          "evidence",
          "recommended_actions",
          "repair_candidates",
          "stop_conditions",
          "retry_count",
          "last_attempt"
        ],
        "properties": {
          "mod": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "last_success_stage": {
            "type": "string"
          },
          "blocking_checks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "next_command": {
            "type": "string"
          },
          "allowed_scripts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence": {
            "type": "object",
            "additionalProperties": true
          },
          "recommended_actions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "repair_candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "stop_conditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "retry_count": {
            "type": "integer",
            "minimum": 0
          },
          "last_attempt": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false
}
