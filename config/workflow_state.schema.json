{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workflow_state.schema.json",
  "title": "Bethesda mod translation workflow state",
  "type": "object",
  "required": [
    "schema_version",
    "game_id",
    "game_profile_version",
    "game_display_name",
    "support_level",
    "interface_translation_encoding",
    "generated_at",
    "policy_path",
    "policy_sha256",
    "states"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "game_id": { "type": "string" },
    "game_profile_version": { "type": "integer", "minimum": 1 },
    "game_display_name": { "type": "string" },
    "support_level": { "type": "string" },
    "interface_translation_encoding": { "type": "string" },
    "generated_at": {
      "type": "string"
    },
    "policy_path": {
      "type": "string"
    },
    "policy_sha256": {
      "type": "string"
    },
    "project_state": {
      "type": "string"
    },
    "readiness_overall_status": {
      "type": "string"
    },
    "state_summary": {
      "type": "object"
    },
    "states": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "mod",
          "state",
          "last_success_stage",
          "blocking_checks",
          "next_actions",
          "allowed_scripts",
          "required_files",
          "evidence",
          "recommended_actions",
          "repair_candidates",
          "stop_conditions",
          "retry_count",
          "last_attempt"
        ],
        "properties": {
          "mod": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "last_success_stage": {
            "type": "string"
          },
          "blocking_checks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "next_actions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "type",
                "source",
                "command",
                "risk",
                "reason",
                "evidence",
                "allowed",
                "refresh_after"
              ],
              "properties": {
                "type": { "type": "string" },
                "source": { "type": "string" },
                "command": { "type": "string" },
                "risk": { "type": "string" },
                "reason": { "type": "string" },
                "evidence": { "type": "string" },
                "allowed": { "type": "boolean" },
                "refresh_after": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "resource_locks": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "dependencies": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "can_run_parallel": { "type": "boolean" },
                "capability": { "type": "string" },
                "operation": { "type": "string" },
                "adapter_id": { "type": "string" },
                "capability_level": { "type": "string" },
                "strict_complete_allowed": { "type": "boolean" },
                "error_code": { "type": "string" },
                "required_agent_capability": {
                  "type": "string",
                  "enum": ["gui:desktop"]
                }
              },
              "additionalProperties": false
            }
          },
          "allowed_scripts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence": {
            "type": "object",
            "additionalProperties": true
          },
          "recommended_actions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "repair_candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "stop_conditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "retry_count": {
            "type": "integer",
            "minimum": 0
          },
          "last_attempt": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false
}
